      },
      "description": "Current circuit breaker states. 0=closed (healthy), 1=open (tripped, failing fast), 2=half-open (testing recovery). Open breakers mean the gateway has cut off traffic to a failing backend.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "center",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "green",
                  "index": 0,
                  "text": "CLOSED (OK)"
                },
                "1": {
                  "color": "red",
                  "index": 1,
                  "text": "OPEN (Tripped)"
                },
                "2": {
                  "color": "yellow",
                  "index": 2,
                  "text": "HALF-OPEN"
                }
              },
              "type": "value"
            }
          ],
