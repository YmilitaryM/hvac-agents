    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Current circuit breaker states for all backend services proxied by the gateway. 0=closed (healthy, traffic flows), 1=open (tripped, traffic blocked), 2=half-open (testing if backend has recovered).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "center",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "green",
                  "index": 0,
                  "text": "CLOSED"
                },
                "1": {
                  "color": "red",
                  "index": 1,
                  "text": "OPEN"
                },
                "2": {
                  "color": "yellow",
                  "index": 2,
                  "text": "HALF-OPEN"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "color-background"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "0": {
                        "color": "green",
                        "index": 0,
                        "text": "CLOSED (OK)"
                      },
                      "1": {
                        "color": "red",
                        "index": 1,
                        "text": "OPEN (TRIPPED)"
                      },
                      "2": {
                        "color": "yellow",
                        "index": 2,
                        "text": "HALF-OPEN"
                      }
                    },
                    "type": "value"
                  }
                ]
              }
            ]
          }
        ]
      },
